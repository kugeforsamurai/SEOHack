# ローカル開発用の API キー設定例
# 本番（Streamlit Cloud）ではこのファイルは使わず、UIから入力する
# このファイルを .env にコピーして、各キーを設定（.env は git ignore される）

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TEXT_MODEL=gpt-4o

# X API (OAuth 1.0a User Context) — Read+Write 権限が必要
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
